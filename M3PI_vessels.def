Bootstrap: docker
From: ubuntu:{{ UBUNTU_VER}}

%arguments
UBUNTU_VER=22.04
R_VER=4.4.3
AFNI_VER=25.0.07
ANTS_VER=2.5.4
C3D_VER=1.0.0
FSL_VER=6.0.7.6
MRTRIX_VER=3.0.7
FS_VER=8.1.0

%environment
# export templateloc=/usr/share/afni/atlases
export AFNIPATH="/opt/afni-AFNI_{{ AFNI_VER }}"
export AFNI_PLUGINPATH="$AFNIPATH"
export templateloc=/usr/share/afni/atlases
export AFNI_AUTOGZIP=YES
export AFNI_COMPRESSOR=GZIP

export R_LIBS="/opt/R/{{ R_VER }}/bin/R"

export ANTSPATH="/opt/ants-{{ ANTS_VER }}/bin"
export ANTSSCRIPTS="/opt/ants-{{ ANTS_VER }}/Scripts"
export LD_LIBRARY_PATH="/opt/ants-{{ ANTS_VER }}/lib:$LD_LIBRARY_PATH"

export C3DPATH="/opt/convert3d-{{ C3D_VER }}"

export FSLDIR="/opt/fsl-{{ FSL_VER }}"
source ${FSLDIR}/etc/fslconf/fsl.sh
export FSLOUTPUTTYPE="NIFTI_GZ"
export FSLMULTIFILEQUIT="TRUE"
export FSLTCLSH="$FSLDIR/bin/fsltclsh"
export FSLWISH="$FSLDIR/bin/fslwish"
export FSLLOCKDIR=""
export FSLMACHINELIST=""
export FSLREMOTECALL=""
export FSLGECUDAQ="cuda.q"

# Not really FS, it's just SynthStrip
export FREESURFER_HOME="/opt/synthstrip-{{ FS_VER }}"

export MRTRIXPATH="/opt/mrtrix3-{{ MRTRIX_VER }}/bin"

export DEBIAN_FRONTEND=noninteractive
export TZ=Europe/Brussels

export PREPROCPATH="/opt/preprocessing"
export PATH="/usr/bin:$PATH:$AFNIPATH:$ANTSPATH:$ANTSSCRIPTS:$C3DPATH/bin:$PREPROCPATH:$PREPROCPATH/00.pipelines:$FSLDIR/bin:$FREESURFER_HOME:$MRTRIXPATH"

%post
# Set install variables, create tmp folder
export TMPDIR="/tmp/general_preproc_build_$( date -u +"%F_%H-%M-%S" )"
[[ -d ${TMPDIR} ]] && rm -rf ${TMPDIR}
mkdir -p ${TMPDIR}
export DEBIAN_FRONTEND=noninteractive
export TZ=Europe/Brussels
apt update -qq
apt install -y -q --no-install-recommends ca-certificates dirmngr gnupg lsb-release

# Install PYTHON things, as well as git and curl.
apt update -qq
apt install -y -q --no-install-recommends \
    build-essential \
    curl \
    git \
    python3.10 \
    python3.10-dev \
    python3-distutils \
    python3-pip \
    python3-rpy2 \
    python-is-python3

pip3 install pip==25.1.1 setuptools==80.7.1 wheel==0.45.1

# Install datalad, nilearn, peakdet, phys2cvr.
pip3 install \
    annexremote==1.6.6 \
    backports.tarfile==1.2.0 \
    bokeh==3.6.3 \
    boto3==1.38.19 \
    botocore==1.38.19 \
    certifi==2025.4.26 \
    cffi==1.17.1 \
    chardet==5.2.0 \
    charset-normalizer==3.4.2 \
    citeproc-py==0.8.2 \
    contourpy==1.3.2 \
    cryptography==45.0.2 \
    cycler==0.12.1 \
    datalad==1.1.6 \
    distro==1.9.0 \
    duecredit==0.10.2 \
    fasteners==0.19 \
    fonttools==4.58.0 \
    humanize==4.12.3 \
    idna==3.10 \
    importlib_metadata==8.7.0 \
    importlib_resources==6.5.2 \
    iso8601==2.1.0 \
    jaraco.classes==3.4.0 \
    jaraco.context==6.0.1 \
    jaraco.functools==4.1.0 \
    jeepney==0.9.0 \
    Jinja2==3.1.6 \
    jmespath==1.0.1 \
    joblib==1.5.0 \
    keyring==25.6.0 \
    keyrings.alt==5.0.2 \
    kiwisolver==1.4.8 \
    latexcodec==3.0.0 \
    loguru==0.7.3 \
    looseversion==1.3.0 \
    lxml==5.4.0 \
    mapca==0.0.5 \
    MarkupSafe==3.0.2 \
    matplotlib==3.10.3 \
    more-itertools==10.7.0 \
    msgpack==1.1.0 \
    nibabel==5.3.2 \
    nigsp==0.19.0 \
    nilearn==0.11.1 \
    numpy==2.2.4 \
    packaging==25.0 \
    pandas==2.2.3 \
    patool==4.0.1 \
    peakdet==0.5.2 \
    phys2cvr==0.19.0 \
    pillow==11.2.1 \
    platformdirs==4.3.8 \
    pybtex==0.24.0 \
    pybtex-apa-style==1.3 \
    pycparser==2.22 \
    pyparsing==3.2.3 \
    python-dateutil==2.9.0.post0 \
    python-gitlab==5.6.0 \
    pytz==2025.2 \
    PyYAML==6.0.2 \
    requests==2.32.3 \
    requests-toolbelt==1.0.0 \
    robustica==0.1.4 \
    s3transfer==0.12.0 \
    scikit-learn==1.6.1 \
    scipy==1.15.2 \
    SecretStorage==3.3.3 \
    simpleitk==2.5.0 \
    six==1.17.0 \
    tedana==25.0.0 \
    threadpoolctl==3.6.0 \
    tornado==6.5 \
    tqdm==4.67.1 \
    typing_extensions==4.13.2 \
    tzdata==2025.2 \
    urllib3==2.4.0 \
    xyzservices==2025.4.0 \
    zipp==3.21.0

# Prepare Install for synthstrip
pip3 install distlib==0.4.0 platformdirs==4.5.0 virtualenv==20.26.2

# Install synthstrip
mkdir -p ${TMPDIR}/synthstrip
git clone -b v{{ FS_VER }} --depth=1 https://github.com/freesurfer/freesurfer.git ${TMPDIR}/synthstrip
cd ${TMPDIR}/synthstrip/mri_synthstrip || exit 1
mkdir -p /opt/synthstrip-{{ FS_VER }}/models
mv mri_synthstrip /opt/synthstrip-{{ FS_VER }}/.
cd /opt/synthstrip-{{ FS_VER }} || exit 1
curl https://surfer.nmr.mgh.harvard.edu/docs/synthstrip/requirements/synthstrip.1.pt --output models/synthstrip.1.pt
curl https://surfer.nmr.mgh.harvard.edu/docs/synthstrip/requirements/synthstrip.nocsf.1.pt --output models/synthstrip.nocsf.1.pt
# curl https://surfer.nmr.mgh.harvard.edu/docs/synthstrip/requirements/synthstrip.infant.1.pt --output models/synthstrip.infant.1.pt

virtualenv -p /usr/bin/python3.10 ssenv

. ssenv/bin/activate

pip3 install https://github.com/freesurfer/surfa/archive/ca4e26317d3556776268ede7de20752743bf49a2.zip
pip3 install --index-url https://download.pytorch.org/whl/cpu torch==2.1.2
pip3 install \
    filelock==3.13.1 \
    fsspec==2024.6.1 \
    importlib_resources==6.5.2 \
    Jinja2==3.1.3 \
    MarkupSafe==2.1.5 \
    mpmath==1.3.0 \
    networkx==3.3 \
    nibabel==5.3.2 \
    numpy==1.26.4 \
    packaging==25.0 \
    pillow==11.3.0 \
    scipy==1.15.3 \
    sympy==1.13.3 \
    triton==2.1.0 \
    typing_extensions==4.15.0 \
    xxhash==3.5.0

deactivate

cd ${TMPDIR} || exit 1
rm -rf ${TMPDIR}/synthstrip

# Install miniconda
mkdir -p ${TMPDIR}/miniconda
cd ${TMPDIR}/miniconda || exit 1
curl "https://repo.anaconda.com/miniconda/Miniconda3-py{{ CONDA_VER }}-Linux-x86_64.sh" -o ./miniconda.sh
bash ./miniconda.sh -b -u -p /opt/miniconda3
cd ${TMPDIR} || exit 1
rm -rf ${TMPDIR}/miniconda

# Install VesSynth
git clone --single-branch --branch fix/modelpath --depth=1 https://github.com/smoia/VesSynth.git /opt/VesSynth
cd /opt/VesSynth

. /opt/miniconda3/bin/activate
conda tos accept --override-channels --channel https://repo.anaconda.com/pkgs/main
conda tos accept --override-channels --channel https://repo.anaconda.com/pkgs/r
conda env create -f vessynth-env.yml -y
conda activate vessynth-env

curl "https://ftp.nmr.mgh.harvard.edu/pub/dist/lcnpublic/dist/VesSynth/models.tar.gz" -o models.tar.gz
tar -xf models.tar.gz --no-same-owner
rm -rf models.tar.gz

conda deactivate

# Install VesselBoost
git clone --single-branch --branch stable_ver_1_0_0_hpc https://github.com/KMarshallX/VesselBoost.git /opt/VesselBoost
cd /opt/VesselBoost
# git checkout 93f0e0548a05d1b5aed011d3c70c15a493f24fb5

. /opt/miniconda3/bin/activate
conda tos accept --override-channels --channel https://repo.anaconda.com/pkgs/main
conda tos accept --override-channels --channel https://repo.anaconda.com/pkgs/r
conda env create -f environment.yml -y
conda activate vessel_boost

mkdir -p saved_models
osf -p abk4p fetch /osfstorage/pretrained_models/t2s_mod_ep1k2_0728 ./saved_models/t2s_mod_ep1k2_0728

conda deactivate

# Prepare repos and install dependencies
apt-key adv --keyserver keyserver.ubuntu.com --recv-keys C9A7585B49D51698710F3A115E25F516B04C661B
apt-key adv --keyserver keyserver.ubuntu.com --recv-keys 6E12762B81063D17BDDD3142F142A4D99F16EB04
echo "deb https://ppa.launchpadcontent.net/marutter/rrutter4.0/ubuntu $(lsb_release -cs) main" | tee -a /etc/apt/sources.list
echo "deb-src https://ppa.launchpadcontent.net/marutter/rrutter4.0/ubuntu $(lsb_release -cs) main" | tee -a /etc/apt/sources.list
echo "deb https://ppa.launchpadcontent.net/c2d4u.team/c2d4u4.0+/ubuntu $(lsb_release -cs) main" | tee -a /etc/apt/sources.list
echo "deb-src https://ppa.launchpadcontent.net/c2d4u.team/c2d4u4.0+/ubuntu $(lsb_release -cs) main" | tee -a /etc/apt/sources.list
apt update -qq
apt install -y -q --no-install-recommends \
    bc \
    bzip2 \
    cmake \
    csvtool \
    dc \
    file \
    freeglut3-dev \
    g++ \
    gcc \
    less \
    libcurl4-openssl-dev \
    libeigen3-dev \
    libexpat1-dev \
    libf2c2-dev \
    libfftw3-3 \
    libfftw3-dev \
    libgdal-dev \
    libgfortran-11-dev \
    libglew-dev \
    libgl1-mesa-dev \
    libgl1-mesa-dri \
    libgl1-mesa-glx \
    libglib2.0-dev \
    libglu1-mesa-dev \
    libglw1-mesa \
    libgomp1 \
    libgsl-dev \
    libgts-dev \
    libjpeg8-dev \
    liblapack3 \
    libopenblas-dev \
    libmotif-dev \
    libnetpbm10-dev \
    libnode-dev \
    libpng16-16 \
    libpng-dev \
    libquadmath0 \
    libqt5opengl5-dev \
    libqt5svg5-dev \
    libtiff5 \
    libtiff5-dev \
    libudunits2-dev \
    libxext-dev \
    libxi-dev \
    libxm4 \
    libxmhtml-dev \
    libxml2-dev \
    libxmu-dev \
    libxmu-headers \
    libxpm-dev \
    libxt-dev \
    m4 \
    make \
    mesa-common-dev \
    nano \
    rsync \
    tcsh \
    qhull-bin \
    xvfb \
    zlib1g-dev
    # libgfortran4 \

# Install Imagemagick
apt install -y -q imagemagick

# Install R
mkdir -p ${TMPDIR}/R
cd ${TMPDIR}/R || exit 1
curl -O https://cdn.rstudio.com/r/ubuntu-2204/pkgs/r-{{ R_VER }}_1_amd64.deb
apt install -y -q ./r-{{ R_VER }}_1_amd64.deb
ln -s /opt/R/{{ R_VER }}/bin/R /usr/local/bin/R
ln -s /opt/R/{{ R_VER }}/bin/Rscript /usr/local/bin/Rscript
cd ${TMPDIR} || exit 1
rm -rf ${TMPDIR}/R

# Install AFNI
mkdir -p ${TMPDIR}/afni
cd ${TMPDIR}/afni || exit 1
ln -s /usr/lib/x86_64-linux-gnu/libgsl.so.27 /usr/lib/x86_64-linux-gnu/libgsl.so.19
ln -s /usr/lib/x86_64-linux-gnu/libXp.so.6 /usr/lib/x86_64-linux-gnu/libXp.so
git clone -b AFNI_{{ AFNI_VER }} --depth=1 https://github.com/afni/afni.git ${TMPDIR}/afni/source
cd source/src || exit 1
cp other_builds/Makefile.linux_ubuntu_16_64_glw_local_shared Makefile
make itall
mv linux_ubuntu_16_64_glw_local_shared /opt/afni-AFNI_{{ AFNI_VER }}
export PATH="/opt/afni-AFNI_{{ AFNI_VER }}:$PATH"
export R_LIBS="/opt/R/{{ R_VER }}/bin/R"
rPkgsInstall -pkgs ALL
cd ${TMPDIR} || exit 1
rm -rf ${TMPDIR}/afni

# Install ANTs
mkdir -p ${TMPDIR}/ants/build
git clone -b v{{ ANTS_VER }} --depth=1 https://github.com/ANTsX/ANTs.git ${TMPDIR}/ants/source
cd ${TMPDIR}/ants/build || exit 1
cmake -DCMAKE_INSTALL_PREFIX=/opt/ants-{{ ANTS_VER }} -DBUILD_SHARED_LIBS=ON -DBUILD_TESTING=OFF ${TMPDIR}/ants/source
make -j 10
mkdir -p /opt/ants-{{ ANTS_VER }}
cd ANTS-build || exit 1
make install
mv ../../source/Scripts/ /opt/ants-{{ ANTS_VER }}
cd ${TMPDIR} || exit 1
rm -rf ${TMPDIR}/ants

# Install C3D
echo "Downloading Convert3D ..."
mkdir -p /opt/convert3d-{{ C3D_VER }}
curl -fsSL https://sourceforge.net/projects/c3d/files/c3d/{{ C3D_VER }}/c3d-{{ C3D_VER }}-Linux-x86_64.tar.gz/download \
| tar -xz -C /opt/convert3d-{{ C3D_VER }} --strip-components 1

# Install FSL
mkdir -p ${TMPDIR}/fsl
cd ${TMPDIR}/fsl || exit 1
curl -fL https://fsl.fmrib.ox.ac.uk/fsldownloads/fslconda/releases/fslinstaller.py --output ./fslinstaller.py
chmod +x fslinstaller.py
python3 fslinstaller.py -d /opt/fsl-{{ FSL_VER }} -V {{ FSL_VER }}
# echo "Installing FSL conda environment ..."
# bash /opt/fsl-{{ FSL_VER }}/etc/fslconf/fslpython_install.sh -f /opt/fsl-{{ FSL_VER }}
cd ${TMPDIR} || exit 1
rm -rf ${TMPDIR}/fsl

# Install MRTrix3
mkdir -p ${TMPDIR}/mrtrix
git clone -b {{ MRTRIX_VER }} --depth=1 https://github.com/MRtrix3/mrtrix3.git ${TMPDIR}/mrtrix
cd ${TMPDIR}/mrtrix || exit 1
./configure
./build
mkdir -p /opt/mrtrix3-{{ MRTRIX_VER }}
mv bin icons lib LICENCE.txt matlab share /opt/mrtrix3-{{ MRTRIX_VER }}/.
cd ${TMPDIR} || exit 1
rm -rf ${TMPDIR}/mrtrix


# Final removal of lists and cleanup
cd /tmp || exit 1
rm -rf ${TMPDIR}
rm -rf /var/lib/apt/lists/*
